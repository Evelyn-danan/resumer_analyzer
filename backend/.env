# 通义千问（推荐，阿里云原生）
DASHSCOPE_API_KEY=sk-28c4f04ef5d046e0a5ab2f7257933c49

# 也可以用 OpenAI 格式兼容接口
OPENAI_API_KEY=sk-28c4f04ef5d046e0a5ab2f7257933c49
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型名称
LLM_MODEL=qwen-plus

# Redis（本地开发用 localhost，生产用阿里云 Tair）
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400          # 缓存 24 小时

# 阿里云 OSS（可选，用于持久化 PDF）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=resume-analyzer
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 服务配置
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,https://your-github-pages-url.github.io
MAX_FILE_SIZE_MB=10
